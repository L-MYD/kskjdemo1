<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.kskj.mapper.RcsLocataionMapper">

    <select id="findOneBylocataion" resultType="com.kskj.pojo.RcsLocataion">
        select *
        from wcs_rcslocataion where locataion=#{locataion};
    </select>
</mapper>