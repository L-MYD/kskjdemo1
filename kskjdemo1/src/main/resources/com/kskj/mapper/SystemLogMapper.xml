<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kskj.mapper.SystemLogMapper">

    <insert id="add">
        INSERT INTO wcs_systemlogs (usertype,
                                    logtype,
                                    level,
                                    message,
                                    module,
                                    operation,
                                    details,
                                    userid,
                                    ipaddress,
                                    createtime,
                                    isarchived)
        VALUES (#{usertype},
                #{logtype},
                #{level},
                #{message},
                #{module},
                #{operation},
                #{details},
                #{userid},
                #{ipaddress},
                #{createtime},
                #{isarchived})
    </insert>
</mapper>