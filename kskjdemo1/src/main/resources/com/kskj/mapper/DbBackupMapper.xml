    <select id="pageFind" resultType="com.kskj.pojo.DbBackup">

SELECT * FROM dbBackup ORDER BY id OFFSET #{star} ROWS FETCH NEXT #{pageSize} ROWS ONLY;
        </select>
    <select id="FindByName" resultType="com.kskj.pojo.DbBackup">
        select * from dbBackup where fileName=#{fileName}
    </select>
    <select id="queryPage" resultType="com.kskj.pojo.DbBackup">
          SELECT * FROM dbBackup OFFSET (#{pageNum} - 1) * #{pageSize} ROWS FETCH NEXT #{pageSize} ROWS ONLY

