<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.kskj.mapper.AgvMapper">
    <update id="updete">
        UPDATE `wcs_agvinfo-rcs`
        SET
            currenttaskId = #{currenttaskId}
        WHERE id = #{id}
    </update>
    <select id="findoneByRobotID" resultType="com.kskj.pojo.rcs.Agv.AgvInfo">
        select * from `wcs_agvinfo-rcs` where agvname=#{agvname}
    </select>
</mapper>